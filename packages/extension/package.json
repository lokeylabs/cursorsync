{
  "name": "cursorsync",
  "displayName": "cursorsync",
  "description": "Real-time, local-first sync of Cursor chat history across devices (PowerSync + Supabase)",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "alexhughes",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cursorsync.status",
        "title": "cursorsync: Show Sync Status"
      },
      {
        "command": "cursorsync.syncNow",
        "title": "cursorsync: Sync Now"
      },
      {
        "command": "cursorsync.signIn",
        "title": "cursorsync: Sign In to Supabase"
      }
    ],
    "configuration": {
      "title": "cursorsync",
      "properties": {
        "cursorsync.supabaseUrl": {
          "type": "string",
          "default": "",
          "description": "Supabase project URL"
        },
        "cursorsync.powersyncUrl": {
          "type": "string",
          "default": "",
          "description": "PowerSync instance URL"
        },
        "cursorsync.syncAgentBlobs": {
          "type": "boolean",
          "default": false,
          "description": "Phase 2: also sync agentKv blobs (~12 GB)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "package": "vsce package"
  },
  "dependencies": {
    "@cursorsync/cursor-store": "workspace:*",
    "@cursorsync/sync-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0"
  }
}
