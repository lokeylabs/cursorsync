{
  "name": "cursorsync",
  "displayName": "cursorsync",
  "description": "Sync your Cursor chat history across all your devices.",
  "version": "0.1.9",
  "license": "MIT",
  "publisher": "lokeylabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/lokeylabs/cursorsync.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorsync",
          "title": "cursorsync",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cursorsync": [
        {
          "id": "cursorsync.panel",
          "name": "Sync",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "cursorsync.signIn",
        "title": "cursorsync: Sign in with GitHub"
      },
      {
        "command": "cursorsync.signOut",
        "title": "cursorsync: Sign out"
      },
      {
        "command": "cursorsync.syncNow",
        "title": "cursorsync: Sync all chats now (push)"
      },
      {
        "command": "cursorsync.pullNow",
        "title": "cursorsync: Pull chats from cloud"
      },
      {
        "command": "cursorsync.backupNow",
        "title": "cursorsync: Back up local chats now"
      },
      {
        "command": "cursorsync.focus",
        "title": "cursorsync: Open panel"
      }
    ],
    "configuration": {
      "title": "cursorsync",
      "properties": {
        "cursorsync.supabaseUrl": {
          "type": "string",
          "default": "https://jwuigueuwlcbyddpnjrz.supabase.co",
          "description": "Supabase project URL (defaults to the cursorsync backend)."
        },
        "cursorsync.supabaseAnonKey": {
          "type": "string",
          "default": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp3dWlndWV1d2xjYnlkZHBuanJ6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4Mzg5ODgsImV4cCI6MjA5NzQxNDk4OH0.NUk6mHEr2jlG0NitUmAlbJCczsz6Wd23ZRVa4WEIArw",
          "description": "Supabase anon (public, RLS-protected) key."
        },
        "cursorsync.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Automatically push new chats and pull remote changes in the background."
        },
        "cursorsync.syncScope": {
          "type": "string",
          "enum": [
            "all",
            "repo"
          ],
          "enumDescriptions": [
            "Sync every chat across all your repos.",
            "Only sync chats that belong to the current repo (matched by git remote)."
          ],
          "default": "all",
          "description": "Whether to sync all chats or isolate sync to the current repository. Toggleable from the cursorsync panel."
        },
        "cursorsync.syncAgentArtifacts": {
          "type": "boolean",
          "default": false,
          "description": "Also sync agent tool-result traces (agentKv) — large and often binary. Off by default; conversations always sync."
        },
        "cursorsync.syncFileSnapshots": {
          "type": "boolean",
          "default": false,
          "description": "Also sync file/checkpoint snapshots (checkpointId, ofsContent) — regenerable. Off by default."
        },
        "cursorsync.syncUiState": {
          "type": "boolean",
          "default": false,
          "description": "Also sync per-machine UI/editor state (ItemTable, diffs). Off by default; mirroring this across devices is usually undesirable."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@cursorsync/cursor-store": "workspace:*",
    "@cursorsync/sync-engine": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0"
  }
}
